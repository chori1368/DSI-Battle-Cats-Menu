                <ui:Button name="epiccapsule" class="Cbutton" style="background-image: url(&quot;project://database/Assets/UI%20Toolkit/rarecapsule.PNG?fileID=2800000&amp;guid=26c9b9dbc46c9994c9d6fe36d78cf9db&amp;type=3#rarecapsule&quot;);"/>
            </ui:VisualElement>
            <ui:VisualElement enabled="true" name="gato" style="position: absolute; top: 40%; left: 65%; right: auto; background-image: url(&quot;project://database/Assets/UI%20Toolkit/gato.png?fileID=2800000&amp;guid=45849668db0b7934fb52486fd985eab1&amp;type=3#gato&quot;); width: 35%; height: 70%;">
