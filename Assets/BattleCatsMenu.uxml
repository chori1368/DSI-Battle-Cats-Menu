<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/UI%20Toolkit/Gatos.uss?fileID=7433441132597879392&amp;guid=3ea10500ff7b36549b9d4b3a726e7ace&amp;type=3#Gatos"/>
    <ui:VisualElement style="flex-grow: 1; background-image: url(&quot;project://database/Assets/UI%20Toolkit/backgourd.png?fileID=2800000&amp;guid=49307d0eef97a0b43840325f90a3158f&amp;type=3#backgourd&quot;);">
        <ui:VisualElement name="top-bar" style="height: 15%;">
            <ui:VisualElement class="header" style="flex-grow: 1; flex-direction: row; justify-content: space-between; align-items: center; align-self: stretch;">
                <ui:Label text="Cat Base" name="Cat-Base"/>
                <ui:VisualElement style="width: 140px; height: 40px;">
                    <ui:Label text="XP" name="XP-Container" style="color: rgb(4, 222, 246); -unity-font-style: bold; height: 33px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;">
                        <ui:VisualElement style="background-color: rgb(225, 186, 119); height: 25px; width: 100px; align-self: flex-end;">
                            <ui:Label text="60545&#10;" style="color: rgb(253, 235, 8); -unity-font-style: bold; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; align-self: flex-end;"/>
                        </ui:VisualElement>
                    </ui:Label>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement class="header2" style="flex-grow: 1; flex-direction: row; justify-content: space-between; margin-top: 5px;">
                <ui:Button text="14952&#10;" name="Level" style="background-color: rgb(32, 32, 32); color: rgb(250, 190, 1);"/>
                <ui:Slider label="dificultad" value="42" high-value="100" name="Dificultad" enabled="true" style="background-color: rgb(255, 255, 255); width: 40%;"/>
