                <ui:Button text="Upgrade" name="upgrade" class="Pbutton"/>
                <ui:Button text="Equip" name="equip" class="Pbutton" style="border-left-color: rgb(1, 1, 1); border-right-color: rgb(1, 1, 1); border-top-color: rgb(1, 1, 1); border-bottom-color: rgb(1, 1, 1);"/>
            </ui:VisualElement>
            <ui:VisualElement name="Mbuttoms" style="height: 15%; flex-direction: row; margin-left: 0%; padding-left: 0;">
