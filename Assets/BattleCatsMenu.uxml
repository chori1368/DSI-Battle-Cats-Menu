            </ui:VisualElement>
            <ui:VisualElement name="Gbuttoms" style="flex-grow: 1; align-self: center; flex-direction: row; background-color: rgb(168, 95, 51); width: 25%; transform-origin: center; border-top-width: 0; padding-top: 0%; padding-right: 0%; padding-bottom: 0%; padding-left: 0%; margin-bottom: 1%; margin-top: -3%; margin-right: 2%; margin-left: 0%;">
