            <ui:VisualElement name="mid-apellido" class="mitf">
                <ui:TextField label="Apellido" name="InputApellido" enabled="true"/>
            </ui:VisualElement>
            <ui:VisualElement name="bottom" style="flex-grow: 1;">
                <ui:Toggle label="Modificar" name="ToggleModificar" style="-unity-font-style: bold;"/>
                <ui:Button text="Crear" name="BotonCrear" style="align-self: flex-end; left: auto; top: 50%; position: relative;"/>
                <ui:Button text="Guardar" name="BotonGuardar" style="width: 25%; height: 25%; top: 20%;"/>
